{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Scene Search",
  "description": "USGS EROS JSON API: Scene Metadata results. data member.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "acquisitionDate": {
        "type": "string",
        "format": "date"
      },
      "spatialFootprint": {
        "description": "geojson",
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "Polygon"
            ]
          },
          "coordinates": {
            "$ref": "#/definitions/polygon"
          }
        },
        "required": [
          "type",
          "coordinates"
        ],
        "additionalProperties": false
      },
      "sceneBounds": {
        "type": "string"
      },
      "browseUrl": {
        "type": "string",
        "format": "uri"
      },
      "entityId": {
        "type": "string"
      },
      "displayId": {
        "type": "string"
      },
      "fgdcMetadataUrl": {
        "type": "string",
        "format": "uri"
      },
      "modifiedDate": {
        "type": "string",
        "format": "date"
      },
      "dataAccess": {},
      "metadataFields": {
        "$ref": "#/definitions/metadataFields"
      }
    },
    "required": [
      "acquisitionDate",
      "spatialFootprint",
      "sceneBounds",
      "browseUrl",
      "entityId",
      "displayId",
      "fgdcMetadataUrl",
      "modifiedDate",
      "metadataFields"
    ],
    "additionalProperties": false
  },
  "definitions": {
    "metadataFields": {
      "description": "New to api 1.4.0. Big list of metadata: name / url / value.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fieldName": {
            "type": "string"
          },
          "descriptionLink": {
            "type": "string",
            "format": "uri"
          },
          "value": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "fieldName",
          "descriptionLink",
          "value"
        ],
        "additionalProperties": false
      }
    },
    "position": {
      "description": "A single position",
      "type": "array",
      "minItems": 2,
      "items": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "additionalItems": false
    },
    "positionArray": {
      "description": "An array of positions",
      "type": "array",
      "items": {
        "$ref": "#/definitions/position"
      }
    },
    "lineString": {
      "description": "An array of two or more positions",
      "allOf": [
        {
          "$ref": "#/definitions/positionArray"
        },
        {
          "minItems": 2
        }
      ]
    },
    "linearRing": {
      "description": "An array of four positions where the first equals the last",
      "allOf": [
        {
          "$ref": "#/definitions/positionArray"
        },
        {
          "minItems": 4
        }
      ]
    },
    "polygon": {
      "description": "An array of linear rings",
      "type": "array",
      "items": {
        "$ref": "#/definitions/linearRing"
      }
    }
  }
}
