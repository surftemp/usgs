{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Dataset Fields",
  "description": "USGS EROS JSON API: Dataset Fields results",
  "type": "object",
  "properties": {
    "errorCode": {},
    "error": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "items": {
        "title": "dataset field",
        "type": "object",
        "properties": {
          "fieldId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "fieldLink": {
            "type": "string",
            "format": "uri"
          },
          "valueList": {
            "type": "array"
          }
        },
        "required": [
          "fieldId",
          "name",
          "fieldLink",
          "valueList"
        ]
      }
    },
    "api_version": {
      "type": "string"
    },
    "executionTime": {
      "type": "number"
    }
  },
  "required": [
    "errorCode",
    "error",
    "data",
    "api_version",
    "executionTime"
  ]
}