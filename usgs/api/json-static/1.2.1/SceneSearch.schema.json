{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Scene Search",
  "description": "USGS EROS JSON API: Scene Search results",
  "type": "object",
  "properties": {
    "errorCode": {},
    "error": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "properties": {
        "numberReturned": {
          "type": "number"
        },
        "totalHits": {
          "type": "number"
        },
        "firstRecord": {
          "type": [
            "number",
            "null"
            ]
        },
        "lastRecord": {
          "type": [
            "number",
            "null"
            ]
        },
        "nextRecord": {
          "type": [
            "number",
            "null"
          ]
        },
        "results": {
          "type": "array",
          "items": {
            "title": "result",
            "type": "object",
            "properties": {
              "acquisitionDate": {
                "type": "string",
                "format": "date"
              },
              "startTime": {
                "type": "string"
              },
              "endTime": {
                "type": "string"
              },
              "lowerLeftCoordinate": {
                "title": "coordinate",
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  }
                },
                "required": [
                  "latitude",
                  "longitude"
                ]
              },
              "upperLeftCoordinate": {
                "title": "coordinate",
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  }
                },
                "required": [
                  "latitude",
                  "longitude"
                ]
              },
              "upperRightCoordinate": {
                "title": "coordinate",
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  }
                },
                "required": [
                  "latitude",
                  "longitude"
                ]
              },
              "lowerRightCoordinate": {
                "title": "coordinate",
                "type": "object",
                "properties": {
                  "latitude": {
                    "type": "number"
                  },
                  "longitude": {
                    "type": "number"
                  }
                },
                "required": [
                  "latitude",
                  "longitude"
                ]
              },
              "sceneBounds": {
                "type": "string"
              },
              "browseUrl": {
                "type": "string",
                "format": "uri"
              },
              "dataAccessUrl": {
                "type": "string",
                "format": "uri"
              },
              "downloadUrl": {
                "type": "string",
                "format": "uri"
              },
              "entityId": {
                "type": "string"
              },
              "displayId": {
                "type": "string"
              },
              "metadataUrl": {
                "type": "string",
                "format": "uri"
              },
              "fgdcMetadataUrl": {
                "type": "string",
                "format": "uri"
              },
              "modifiedDate": {
                "type": "string",
                "format": "date"
              },
              "orderUrl": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "uri"
              },
              "bulkOrdered": {
                "type": "boolean"
              },
              "ordered": {
                "type": "boolean"
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "acquisitionDate",
              "startTime",
              "endTime",
              "lowerLeftCoordinate",
              "upperLeftCoordinate",
              "upperRightCoordinate",
              "lowerRightCoordinate",
              "sceneBounds",
              "browseUrl",
              "dataAccessUrl",
              "downloadUrl",
              "entityId",
              "displayId",
              "metadataUrl",
              "fgdcMetadataUrl",
              "modifiedDate",
              "orderUrl",
              "bulkOrdered",
              "ordered",
              "summary"
            ]
          }
        }
      },
      "required": [
        "numberReturned",
        "totalHits",
        "firstRecord",
        "lastRecord",
        "nextRecord",
        "results"
      ]
    },
    "api_version": {
      "type": "string"
    },
    "executionTime": {
      "type": "number"
    }
  },
  "required": [
    "errorCode",
    "error",
    "data",
    "api_version",
    "executionTime"
  ]
}