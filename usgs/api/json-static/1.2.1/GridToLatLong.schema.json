{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "GridToLatLong",
  "description": "USGS EROS JSON API: GridToLatLong results",
  "type": "object",
  "properties": {
    "errorCode": {},
    "error": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "properties": {
        "shape": {
          "type": "string"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              }
            },
            "required": [
              "latitude",
              "longitude"
            ]
          }
        }
      },
      "required": [
        "shape",
        "coordinates"
      ]
    },
    "api_version": {
      "type": "string"
    },
    "executionTime": {
      "type": "number"
    }
  },
  "required": [
    "errorCode",
    "error",
    "data",
    "api_version",
    "executionTime"
  ]
}