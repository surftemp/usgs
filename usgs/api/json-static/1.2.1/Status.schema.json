{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Status",
  "description": "USGS EROS JSON API: Status results",
  "type": "object",
  "properties": {
    "errorCode": {},
    "error": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "properties": {
        "build_date": {
          "type": "string"
        }
      },
      "required": [
        "build_date"
      ]
    },
    "api_version": {
      "type": "string"
    },
    "executionTime": {
      "type": "number"
    }
  },
  "required": [
    "errorCode",
    "error",
    "data",
    "api_version",
    "executionTime"
  ]
}