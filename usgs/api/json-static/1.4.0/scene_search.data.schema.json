{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Scene Search",
  "description": "USGS EROS JSON API: Scene Search results. data member.",
  "type": "object",
  "properties": {
    "numberReturned": {
      "type": "number"
    },
    "totalHits": {
      "type": "number"
    },
    "firstRecord": {
      "type": [
        "number",
        "null"
      ]
    },
    "lastRecord": {
      "type": [
        "number",
        "null"
      ]
    },
    "nextRecord": {
      "type": [
        "number",
        "null"
      ]
    },
    "results": {
      "type": "array",
      "items": {
        "title": "result",
        "type": "object",
        "properties": {
          "acquisitionDate": {
            "type": "string",
            "format": "date"
          },
          "startTime": {
            "type": "string",
            "format": "date"
          },
          "endTime": {
            "type": "string",
            "format": "date"
          },
          "spatialFootprint": {
            "description": "geojson",
            "type": "object",
            "properties": {
              "type": {
                "enum": [
                  "Polygon"
                ]
              },
              "coordinates": {
                "$ref": "#/definitions/polygon"
              }
            },
            "required": [
              "type",
              "coordinates"
            ],
            "additionalProperties": false
          },
          "sceneBounds": {
            "type": "string"
          },
          "browseUrl": {
            "type": "string",
            "format": "uri"
          },
          "dataAccessUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "downloadUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "entityId": {
            "type": "string"
          },
          "displayId": {
            "type": "string"
          },
          "metadataUrl": {
            "type": "string",
            "format": "uri"
          },
          "fgdcMetadataUrl": {
            "type": "string",
            "format": "uri"
          },
          "modifiedDate": {
            "type": "string",
            "format": "date"
          },
          "orderUrl": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "bulkOrdered": {
            "type": "boolean"
          },
          "ordered": {
            "type": "boolean"
          },
          "summary": {
            "type": "string"
          }
        },
        "required": [
          "acquisitionDate",
          "startTime",
          "endTime",
          "spatialFootprint",
          "sceneBounds",
          "browseUrl",
          "dataAccessUrl",
          "downloadUrl",
          "entityId",
          "displayId",
          "metadataUrl",
          "fgdcMetadataUrl",
          "modifiedDate",
          "orderUrl",
          "bulkOrdered",
          "ordered",
          "summary"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "numberReturned",
    "totalHits",
    "firstRecord",
    "lastRecord",
    "nextRecord",
    "results"
  ],
  "additionalProperties": false,
  "definitions": {
    "position": {
      "description": "A single position",
      "type": "array",
      "minItems": 2,
      "items": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ],
      "additionalItems": false
    },
    "positionArray": {
      "description": "An array of positions",
      "type": "array",
      "items": {
        "$ref": "#/definitions/position"
      }
    },
    "lineString": {
      "description": "An array of two or more positions",
      "allOf": [
        {
          "$ref": "#/definitions/positionArray"
        },
        {
          "minItems": 2
        }
      ]
    },
    "linearRing": {
      "description": "An array of four positions where the first equals the last",
      "allOf": [
        {
          "$ref": "#/definitions/positionArray"
        },
        {
          "minItems": 4
        }
      ]
    },
    "polygon": {
      "description": "An array of linear rings",
      "type": "array",
      "items": {
        "$ref": "#/definitions/linearRing"
      }
    }
  }
}